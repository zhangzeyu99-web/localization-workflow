# 复制为同目录下的 .env（文件名就是 .env）
# 路径请写完整绝对路径；本仓库脚本不会展开 %LOCALAPPDATA% 这类占位符。

CLASH_VERGE_EXE=C:\Program Files\Clash Verge\clash-verge.exe
CLASH_MIXED_PORT=7897

# 示例（请改成你机器上的真实路径）：
# CODEX_DESKTOP_EXE=C:\Users\YourName\AppData\Local\Programs\OpenAI\CodexDesktop\Codex.exe
# CODEX_CLI_EXE=C:\Users\YourName\AppData\Local\Programs\OpenAI\Codex\bin\codex.exe
